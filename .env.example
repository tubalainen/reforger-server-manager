# ============================================================
# Reforger Server Manager — configuration
# Copy to .env and adjust. Every setting the stack needs lives here.
# ============================================================

# --- Web GUI ---------------------------------------------------------------
# Address the GUI binds to on the HOST. Use 127.0.0.1 behind a reverse proxy,
# or 0.0.0.0 to expose directly (built-in login still applies — use a strong
# password and preferably a firewall).
WEB_BIND=127.0.0.1
WEB_PORT=7780

# --- Authentication (REQUIRED) ----------------------------------------------
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-now

# Built-in login. Leave as 'true' unless a reverse proxy in front of the app
# (NGINX, Caddy, Authelia, …) enforces authentication for you. Setting this to
# 'false' DISABLES the username/password prompt entirely — the GUI, which
# controls Docker, becomes fully open to anyone who can reach it. Only do this
# behind a proxy that authenticates every request.
AUTH_ENABLED=true

# Secret used to sign session cookies. Generate with:
#   openssl rand -hex 32
# If left empty a random secret is generated at startup (all sessions are
# invalidated whenever the container restarts).
SESSION_SECRET=

# Session lifetime in hours (default 7 days)
SESSION_TTL_HOURS=168

# --- Docker integration ------------------------------------------------------
# Which build of the manager itself to run, as an image tag.
#   latest   -> follow every release. The Windows start.ps1 pulls it on start,
#               so a double-click keeps you up to date. On Linux run
#               `docker compose pull` before `up -d` to update.
#   vX.Y.Z   -> LOCK the manager to that exact release so it never changes,
#               e.g. MANAGER_VERSION=v0.31.0
# Releases: https://github.com/tubalainen/reforger-server-manager/releases
MANAGER_VERSION=latest

# Image used for spawned Arma Reforger Dedicated Server instances.
# The default (ACE Mod's image) consumes a mounted config.json via ARMA_CONFIG.
REFORGER_SERVER_IMAGE=ghcr.io/acemod/arma-reforger:latest

# Image used for the one-shot "Download server files" jobs.
STEAMCMD_IMAGE=steamcmd/steamcmd:latest

# Abort a server-file download if it runs longer than this many minutes.
STEAMCMD_TIMEOUT_MINUTES=60

# Delete per-session server log/crash folders older than this many days.
LOG_RETENTION_DAYS=14

# --- Server networking --------------------------------------------------------
# Public IP address of this machine, advertised to the Arma backend.
# Leave empty to auto-detect.
PUBLIC_ADDRESS=

# Host UDP port ranges the manager may lease to server instances
# (one port of each kind per instance).
GAME_PORT_RANGE=2001-2020
A2S_PORT_RANGE=17777-17796
RCON_PORT_RANGE=19999-20018

# --- Misc ---------------------------------------------------------------------
TZ=Europe/Stockholm

# --- Advanced (rarely changed; defaults are right for the compose setup) -------
# Where the manager keeps its database, per-instance configs, profiles and logs.
# Must match the container path mounted in docker-compose.yaml.
DATA_DIR=/data

# Where the downloaded server files live, one folder per branch.
SERVERFILES_DIR=/serverfiles

# The Docker network the manager attaches spawned server containers to. Must match
# the network named in docker-compose.yaml.
DOCKER_NETWORK=reforger-net

# Directory the built web GUI is served from. Set in the image; leave empty to run
# the API without a frontend (development).
# STATIC_DIR=/app/static

# Mark the session cookie "secure" so the browser only ever sends it over HTTPS.
# Turn this on when a TLS reverse proxy fronts the GUI. Leave false for the plain
# HTTP localhost default, where a secure cookie would never be sent at all.
SESSION_COOKIE_SECURE=false
